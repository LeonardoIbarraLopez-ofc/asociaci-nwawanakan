rules_version = '2';

// Reglas de seguridad de Firestore para el CMS de Wawanakan.
// - Lectura pública: el sitio carga el contenido sin autenticación.
// - Escritura: solo usuarios autenticados (el administrador con email/password).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
